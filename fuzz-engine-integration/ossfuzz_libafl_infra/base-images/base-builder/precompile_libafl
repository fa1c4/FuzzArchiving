echo "Precompiling LibAFL libFuzzer runtime"

runtime_dir="$SRC/LibAFL/crates/libafl_libfuzzer_runtime"
install_dir="/usr/local/lib/libafl"

unset CFLAGS
unset CXXFLAGS
unset RUSTFLAGS

libclang_path="$(find /usr/lib /usr/local/lib -type f \( -name 'libclang.so*' -o -name 'libclang-*.so*' \) -print -quit 2>/dev/null || true)"
if [[ -n "$libclang_path" ]]; then
  export LIBCLANG_PATH="$(dirname "$libclang_path")"
fi

pushd "$runtime_dir" > /dev/null
./build.sh --toolchain "$RUSTUP_TOOLCHAIN"
mkdir -p "$install_dir"
cp libFuzzer.a "$install_dir/libFuzzer.a"
popd > /dev/null
